        {"month": 4, "period": "上旬", "task_type": "fertilizing", "description": "玉肥を置き肥。新芽が伸びる前の元肥として施す。"},
        {"month": 5, "period": "中旬", "task_type": "bud_pinching", "description": "新芽（みどり）の長さが揃ったら、強い芽は元から、弱い芽は半分残してつまむ。"},
        {"month": 6, "period": "下旬", "task_type": "fertilizing", "description": "肥料止め。梅雨明けまでに施肥を控え、徒長を抑える。"},
        {"month": 11, "period": "中旬", "task_type": "defoliation", "description": "古葉抜き。前年の古い葉を手で引き抜き、内部の日当たりと風通しを確保する。"},
        {"month": 12, "period": "上旬", "task_type": "wiring", "description": "休眠期に入ったら針金かけ。樹液の動きが少なく形が決まりやすい。"}
